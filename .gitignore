# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# electron-builder
/dist

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env — gizli/ortam dosyaları; şablon repoda kalır
.env
.env.*
!.env.example
!.env.production.example
!.env.production

# docker — yerel override (secrets / makineye özel compose)
docker-compose.override.yml
docker-compose.*.local.yml

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# swagger (API dokümantasyon çıktısı)
/swagger.json
